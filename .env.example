# Copy this file to ".env" and fill in real values.
# Never commit your real .env — it's in .gitignore.

# --- LLM provider (defaults to Google Gemini's OpenAI-compatible free tier) ---
# Get a key at https://aistudio.google.com/apikey
LLM_API_KEY=your-gemini-api-key-here

# Override the next three only if you're using a different OpenAI-compatible
# provider (Together, Groq, vLLM, OpenAI itself, etc.).
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CHAT_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# --- Backwards-compat / alternative: real OpenAI ---
# If LLM_API_KEY is empty AND OPENAI_API_KEY is set, the bot uses
# https://api.openai.com/v1/ with gpt-4o-mini + text-embedding-3-small.
# OPENAI_API_KEY=sk-your-openai-key-here

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Optional: override the escalation threshold (default 0.80)
# ESCALATION_THRESHOLD=0.80
